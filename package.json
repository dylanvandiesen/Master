{
  "name": "RoboTheme",
  "version": "1.0.0",
  "description": "Houdini playground",
  "private": true,
  "type": "module",
  "scripts": {
    "env": "node scripts/env/run-env.mjs",
    "env:up": "node scripts/env/run-env.mjs up",
    "env:status": "node scripts/env/run-env.mjs status",
    "env:down": "node scripts/env/run-env.mjs down",
    "projects:dev": "gulp dev",
    "projects:dev:all": "gulp devAll",
    "projects:build": "gulp build",
    "projects:build:all": "gulp buildAll",
    "projects:clean": "gulp clean",
    "projects:scaffold": "gulp scaffold",
    "projects:list": "gulp listProjects",
    "agent:spawn": "node scripts/chat/spawn-super-agent.mjs --mode=quick",
    "agent:spawn:full": "node scripts/chat/spawn-super-agent.mjs --mode=full",
    "panel": "node remote-console/server.mjs --host=127.0.0.1",
    "panel:local": "node remote-console/server.mjs --host=127.0.0.1",
    "panel:remote": "node remote-console/server.mjs --host=0.0.0.0 --security=auto",
    "panel:lan": "node remote-console/server.mjs --host=0.0.0.0 --security=auto",
    "dev": "gulp dev",
    "dev:project": "gulp dev",
    "dev:all": "gulp devAll",
    "build": "gulp build",
    "build:project": "gulp build",
    "build:all": "gulp buildAll",
    "clean": "gulp clean",
    "scaffold": "gulp scaffold",
    "list:projects": "gulp listProjects",
    "chat:new": "node scripts/chat/run-prepare-chat-instance.mjs --mode=standard",
    "chat:new:standard": "node scripts/chat/run-prepare-chat-instance.mjs --mode=standard",
    "chat:new:full": "node scripts/chat/run-prepare-chat-instance.mjs --mode=full",
    "chat:new:quick": "node scripts/chat/run-prepare-chat-instance.mjs --mode=quick",
    "chat:briefing": "cmd /c npm run chat:briefing:project && cmd /c npm run chat:briefing:commander && cmd /c npm run chat:briefing:system",
    "chat:briefing:project": "powershell -ExecutionPolicy Bypass -File scripts/chat/new-chat-briefing.ps1 -Mode project -OutputPath .agency/chat/latest-briefing.md",
    "chat:briefing:commander": "powershell -ExecutionPolicy Bypass -File scripts/chat/new-chat-briefing.ps1 -Mode commander -OutputPath .agency/chat/latest-commander-briefing.md",
    "chat:briefing:system": "powershell -ExecutionPolicy Bypass -File scripts/chat/new-chat-briefing.ps1 -Mode system -OutputPath .agency/chat/latest-system-briefing.md",
    "super:context": "node scripts/chat/run-super-agent-context.mjs",
    "super:bootstrap": "node scripts/chat/run-super-agent-bootstrap.mjs --mode=quick",
    "super:bootstrap:standard": "node scripts/chat/run-super-agent-bootstrap.mjs --mode=standard",
    "super:bootstrap:full": "node scripts/chat/run-super-agent-bootstrap.mjs --mode=full",
    "super:agent": "node scripts/chat/spawn-super-agent.mjs --mode=quick",
    "super:agent:full": "node scripts/chat/spawn-super-agent.mjs --mode=full",
    "mcp:prep": "powershell -ExecutionPolicy Bypass -File scripts/chat/prepare-mcp.ps1",
    "mcp:start:filesystem": "cmd /c npm --prefix mcp run start:filesystem",
    "mcp:start:memory": "cmd /c npm --prefix mcp run start:memory",
    "mcp:start:browser:eyes": "cmd /c npm --prefix mcp run start:browser-eyes",
    "mcp:start:github:legacy": "cmd /c npm --prefix mcp run start:github:legacy",
    "mcp:start:github:modern:docker": "cmd /c npm --prefix mcp run start:github:modern:docker",
    "skills:list": "powershell -ExecutionPolicy Bypass -Command \"Get-ChildItem skills -Directory | Select-Object -ExpandProperty Name\"",
    "skills:validate": "powershell -ExecutionPolicy Bypass -File scripts/chat/validate-skills.ps1",
    "security:secrets": "powershell -ExecutionPolicy Bypass -File scripts/security/scan-secrets.ps1",
    "commander": "npm run commander:local --",
    "commander:local": "node remote-console/server.mjs --host=127.0.0.1",
    "commander:remote": "node remote-console/server.mjs --host=0.0.0.0 --security=auto",
    "commander:lan": "npm run commander:remote --",
    "commander:start": "npm run commander:start:local --",
    "commander:start:local": "node scripts/remote/start-panel-stack.mjs --mode=local",
    "commander:start:remote": "node scripts/remote/start-panel-stack.mjs --mode=remote",
    "commander:start:remote:full": "cmd /c npm run chat:new:full && cmd /c npm run commander:start:remote",
    "commander:start:all": "cmd /c npm run commander:start:remote:full",
    "commander:test:domterm": "node scripts/remote/test-domterm-terminal.mjs",
    "commander:test:terminal": "node scripts/remote/test-domterm-terminal.mjs",
    "commander:terminal:attach": "node scripts/remote/attach-shared-terminal.mjs",
    "commander:terminal:attach:once": "node scripts/remote/attach-shared-terminal.mjs --once=true --quiet=true",
    "commander:agent:status": "node scripts/remote/publish-agent-update.mjs status",
    "commander:agent:reply": "node scripts/remote/publish-agent-update.mjs reply",
    "commander:relay:codex:watch": "node scripts/remote/codex-interactive-relay.mjs watch --session-name=codex-chat --codex-use-last=false",
    "commander:relay:codex:once": "node scripts/remote/codex-interactive-relay.mjs once --session-name=codex-chat --codex-use-last=false"
  },
  "devDependencies": {
    "@girder/fontello": "^3.2.11",
    "autoprefixer": "^10.4.14",
    "del": "^7.0.0",
    "esbuild": "^0.27.3",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-cli": "^3.1.0",
    "gulp-concat": "^2.6.1",
    "gulp-dart-sass": "^1.1.0",
    "gulp-livereload": "^4.0.2",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^9.0.1",
    "gulp-rename": "^2.0.0",
    "gulp-sourcemaps": "^2.6.5",
    "gulp-uglify": "^3.0.2",
    "sass": "^1.63.0",
    "sharp": "^0.32.0",
    "through2": "^4.0.2"
  },
  "dependencies": {
    "DomTerm": "github:PerBothner/DomTerm",
    "gsap": "^3.14.2",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0",
    "xterm": "^5.3.0"
  }
}
