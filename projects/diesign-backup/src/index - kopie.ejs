                <div class="content-wrapper">
                  <div class="thumbnails">
										<% projects.forEach(function(project) { %>
										<div class="thumbnail">
											<button popovertarget="<%= project.id %>" class="pop-btn open">
											<div class="hoverBox">
                        <div class="ripple wrapper" data-effect="ripple"></div>
											</div>
											<picture>
												<source srcset="/<%= project.thumb.avif %>" type="image/avif">
												<source srcset="/<%= project.thumb.webp %>" type="image/webp">
												<source srcset="/<%= project.thumb.jpg %>" type="image/jpeg">
												<img class="d-loading" src="/<%= project.thumb.jpg %>" alt="<%= project.thumb.alt %>" width="<%= project.thumb.width %>" height="<%= project.thumb.height %>" loading="lazy" style="aspect-ratio:<%= project.thumb.width %>/<%= project.thumb.height %>">
											</picture>
											</button>
										</div>
										<% }); %>
									</div>
                </div>
                <% projects.forEach(function(project) { %>
                  <div id="<%= project.id %>" class="project-pop" popover tabindex="0">
                    <div class="star-bg"></div>
                    <div class="bg-overlay"></div>
                    <div class="oversnap-scroller">
                      <div class="oversnap-body">
                        <% project.figures.forEach(function(fig, figIndex) { %>
                          <figure>
                            <% if (fig.type === "picture") { %>
                              <picture class=" <%= fig.class %>" >
                                <% fig.sources.forEach(function(source) { %>
                                  <source 
                                    srcset="/<%= source.srcset %>"
                                    type="<%= source.type %>"
                                  >
                                <% }); %>
                                <img 
                                  class="d-loading"
                                  src="/<%= fig.img.src %>"
                                  alt="<%= fig.img.alt %>" 
                                  width="<%= fig.img.width %>" 
                                  height="<%= fig.img.height %>" 
                                  loading="<%= figIndex === 0 ? 'lazy' : 'lazy' %>"
                                  
                                >
                              </picture>
                            <% } else if (fig.type === "video") { %>
                              <div
                                class="video-placeholder <%= fig.class %>"
                                data-video='<%- JSON.stringify({
                                  title: fig.title,
                                  width: fig.width,
                                  height: fig.height,
                                  sources: fig.sources,
                                  autoplay: true,
                                  loop: true,
                                  muted: true,
                                  controls: true,
                                  controlsList: "play nodownload noplaybackrate",
                                  disableRemotePlayback: true,
                                  disablePictureInPicture: true
                                }) %>'
                              ></div>
                            <% } %>

                            <% if (figIndex === 0 && project.content) { 
                              const fields = [
                                { key: 'title', label: 'Project' },
                                { key: 'client', label: 'Opdrachtgever' },
                                { key: 'year', label: 'Jaartal' },
                                { key: 'excerpt', label: 'Samenvatting' },
                                { key: 'goals', label: 'Doelstellingen' },
                                { key: 'role', label: 'Mijn rol' },
                                { key: 'challenges', label: 'Uitdagingen' },
                                { key: 'results', label: 'Resultaten' },
                                // { key: 'tools', label: 'Tools' },
                                { key: 'toolset', label: 'Toolset' },
                                { key: 'skillset', label: 'Vaardigheden' }
                              ];
                            %>
                              <div class="project-content" style="opacity:0;">
                                <figcaption class="content-bg">
                                  <details>
                                    <summary>
                                      <div class="ripple wrapper" data-effect="ripple"></div>
                                      <span>Projectdetails</span>
                                      <% // <div class="rippleJS"></div> %>
                                    </summary>
                                    <div class="content">
                                    
                                      <% fields.forEach(function(field) { 
                                        const value = project.content[field.key];

                                        if (value) { %>
                                        
                                          <h3><%= field.label %></h3>
                                          
                                          <% if (Array.isArray(value)) { %>
                                          
                                            <% 
                                              // Check of het een array van objecten met een 'categorie'-key is
                                              const hasCategories = value[0] && value[0].categorie; 
                                            %>

                                            <% if (hasCategories) { %>
                                              <div class="subcategory">
                                                <% 
                                                  // Groepeer de subitems per categorie
                                                  const categories = value.reduce((acc, item) => {
                                                    if (!acc[item.categorie]) {
                                                      acc[item.categorie] = [];
                                                    }
                                                    acc[item.categorie].push(item.subitem);
                                                    return acc;
                                                  }, {});
                                                %>
                                                <% value.forEach(function(category) { %>
                                                  <h4>✦ <%= category.categorie %></h4>
                                                  <ul>
                                                    <% category.subitems.forEach(function(subitem) { %>
                                                      <li><%= subitem %></li>
                                                    <% }); %>
                                                  </ul>
                                                <% }); %>
                                              </div>
                                            <% } else { %>
                                            
                                              <ul>
                                                <% value.forEach(function(item) { %>
                                                  <li><%= item %></li>
                                                <% }); %>
                                              </ul>
                                              
                                            <% } %>

                                          <% } else { %>
                                          
                                            <p><%= value %></p>
                                            
                                          <% } %>
                                          
                                      <% } }); %>

                                    </div>
                                  </details>
                                </figcaption>
                              </div>
                            <% } %>

                          </figure>
                        <% }); %>
                      </div>
                    </div>
                    <ul class="pop-nav">
                    <li>
                      <button class="icon prev ripple">
                      </button>
                    </li>
                    <li>
                      <button popovertarget="<%= project.id %>" class="icon close ripple">
                      </button>
                    </li>
                    <li>
                      <button class="icon next ripple">
                      </button>
                    </li>
                    </ul>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        </div>
        <div id="about" class="tab-pane-container">
