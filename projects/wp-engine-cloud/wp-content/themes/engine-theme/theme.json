{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "background", "name": "Background", "color": "#f7f8fb" },
        { "slug": "surface", "name": "Surface", "color": "#ffffff" },
        { "slug": "text", "name": "Text", "color": "#182230" },
        { "slug": "muted", "name": "Muted", "color": "#5f6b7a" },
        { "slug": "brand", "name": "Brand", "color": "#2456f5" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw"],
      "blockGap": "1.25rem"
    },
    "typography": {
      "fluid": true,
      "fontSizes": [
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.25rem", "name": "Large" },
        { "slug": "xl", "size": "2rem", "name": "XL" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "lineHeight": "1.6"
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
