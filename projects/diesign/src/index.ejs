<!DOCTYPE html>
<html lang="nl">
  <head>
    <%- include('./templates/partials/head') %>
  </head>
  <body style="background-color:hsl(285,96%,20%);">
    <%- include('./templates/partials/loader') %>
    <div id="app" class="content-container" data-route="home" style="display:none;">
      <div class="signal-overlay" aria-hidden="true">
        <canvas class="signal-overlay-canvas" data-effect="signal-noise"></canvas>
      </div>

      <%- include('./templates/partials/brand') %>

      <section class="tab-panes" aria-live="polite">
        <div id="home" class="tab-pane-container"></div>
        <div class="home-route-overlay" data-home-overlay aria-hidden="true"></div>

        <%
          const fields = [
            { key: 'title', label: 'Project' },
            { key: 'client', label: 'Opdrachtgever' },
            { key: 'year', label: 'Jaartal' },
            { key: 'excerpt', label: 'Samenvatting' },
            { key: 'goals', label: 'Doelstellingen' },
            { key: 'role', label: 'Mijn rol' },
            { key: 'challenges', label: 'Uitdagingen' },
            { key: 'results', label: 'Resultaten' },
            { key: 'toolset', label: 'Toolset' },
            { key: 'skillset', label: 'Vaardigheden' }
          ];
        %>

        <template id="route-template-home">
          <%- include('./templates/routes/home') %>
        </template>

        <template id="route-template-work">
          <%- include('./templates/routes/work', { projects }) %>
        </template>

        <% projects.forEach(function(project) { %>
          <template id="template-<%= project.id %>">
            <%- include('./templates/project/popover', { project, fields }) %>
          </template>
        <% }); %>

        <template id="route-template-about">
          <%- include('./templates/routes/about') %>
        </template>

        <template id="route-template-contact">
          <%- include('./templates/routes/contact') %>
        </template>

        <%- include('./templates/partials/panel-shell') %>
      </section>

      <%- include('./templates/partials/nav') %>
      <%- include('./templates/partials/stage') %>
    </div>

    <%- include('./templates/partials/scripts') %>
  </body>
</html>
